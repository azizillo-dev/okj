# ==============================================================================
# OKJ PLATFORM - ENVIRONMENT VARIABLES CONFIGURATION (.env.example)
# Nega bu fayl kerak: Barcha xavfsiz parollar va muhit sozlamalari kod ichiga 
# yozilmasdan (hardcoded bo'lmasdan) faqat .env orqali yuklanishi shart (Twelve-Factor App).
# ==============================================================================

# Django Environment Setting ('local' or 'production')
DJANGO_SETTINGS_MODULE=config.settings.production
DJANGO_SECRET_KEY=django-insecure-change-this-to-a-secure-random-string-50-chars
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,api.okj.uz

# Domain & SSL (Nginx & Certbot uchun)
DOMAIN=api.okj.uz
CERTBOT_EMAIL=admin@okj.uz

# PostgreSQL Database Configuration
POSTGRES_DB=okj_db
POSTGRES_USER=okj_user
POSTGRES_PASSWORD=CEO517984
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgres://okj_user:CEO517984@postgres:5432/okj_db

# Redis Cache & Channel Layer Configuration
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=okj_redis_secret_password_2026
REDIS_URL=redis://:okj_redis_secret_password_2026@redis:6379/0

# Cloudflare R2 / AWS S3 Storage Configuration
# Nega R2: S3 dan 10 barobar arzon va Egress (ma'lumot yuklab olish) narxi 0 dollar.
CLOUDFLARE_R2_ACCOUNT_ID=your_cloudflare_account_id_here
CLOUDFLARE_R2_ACCESS_KEY_ID=your_r2_access_key
CLOUDFLARE_R2_SECRET_ACCESS_KEY=your_r2_secret_key
CLOUDFLARE_R2_BUCKET_NAME=okj-media-bucket
CLOUDFLARE_R2_CUSTOM_DOMAIN=media.okj.uz
USE_CLOUDFLARE_R2=False

# JWT Authentication Configuration
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60
JWT_REFRESH_TOKEN_LIFETIME_DAYS=30
JWT_SIGNING_KEY=change-this-jwt-secret-key-in-production

# CORS & Frontend Origins (Next.js & Flutter Web)
CORS_ALLOWED_ORIGINS=http://localhost:3000,https://okj.uz,https://www.okj.uz

# Monitoring & Error Tracking (Sentry)
SENTRY_DSN=
